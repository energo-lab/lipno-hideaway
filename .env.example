# Supabase — get these from: supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# NOTE: Without these, the site runs in DEMO mode with sample data.
# Everything works — you can test all features immediately.
# When you add real Supabase credentials, it switches to live data.
