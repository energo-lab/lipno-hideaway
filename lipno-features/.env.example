# ============================================================
# .env.local – Lipno Hideaway
# Zkopírujte do .env.local a vyplňte hodnoty
# ============================================================

# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...     # Pouze na serveru! Nikdy v klientu.

# ── Comgate ──────────────────────────────────────────────
COMGATE_MERCHANT_ID=123456           # Z portálu Comgate
COMGATE_SECRET=your_secret_here      # Z portálu Comgate
COMGATE_TEST=true                    # Přepnout na false v produkci!

# ── Resend (e-maily) ─────────────────────────────────────
RESEND_API_KEY=re_xxxx               # Z https://resend.com
EMAIL_FROM=Lipno Hideaway <rezervace@lipno20.cz>
ADMIN_EMAIL=vas@email.cz             # Kam chodí admin notifikace

# ── Claude AI (chat) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Obecné ───────────────────────────────────────────────
NEXT_PUBLIC_URL=https://www.lipno20.cz   # Bez lomítka na konci
PRICE_PER_NIGHT=4500                     # Výchozí cena/noc v Kč
DEPOSIT_PERCENT=30                        # Záloha v % z celkové ceny
